# Komodo Periphery agent passkey.
# The REAL value lives in Vaultwarden ("komodo-periphery") and on each host at
# /opt/komodo-periphery/periphery.env (chmod 600). Same passkey across ALL periphery agents.
# NEVER commit the real value to git — copy this file to periphery.env and fill it in on-host.
PERIPHERY_PASSKEYS=<from Vaultwarden: komodo-periphery>
